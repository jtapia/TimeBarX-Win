<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeBarX.App.UpgradeProDialog"
        Title="Unlock TimeBarX Pro"
        WindowStartupLocation="CenterScreen"
        Width="420" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="True">
    <StackPanel Margin="20" Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Background="#1E3A8A" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="11" FontWeight="SemiBold" />
            </Border>
            <TextBlock Text="Unlock TimeBarX Pro" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock TextWrapping="Wrap"
                   Text="A one-time unlock for power users — $2.99 introductory sale (regular $4.99). No subscription, no account." />

        <StackPanel Spacing="6">
            <TextBlock Text="• Custom colors and gradient mode" />
            <TextBlock Text="• Always above everything (experimental)" />
            <TextBlock Text="• Saved custom presets" />
            <TextBlock Text="• timebarx:// URI automation (PowerToys, Flow, AutoHotkey)" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Name="DismissButton" Content="Not now" Click="OnDismissClicked" />
            <Button Name="RestoreButton" Content="Restore Purchase" Click="OnRestoreClicked" />
            <Button Name="BuyButton" Content="Unlock $2.99" Click="OnBuyClicked"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" />
        </StackPanel>

        <!-- Direct-channel entry point: users who bought via Gumroad paste their
             license key here. Hidden behind a "have a key?" button to keep the
             primary-flow visual weight on Buy. -->
        <Button Name="ShowLicenseButton"
                Content="I have a license key…"
                Click="OnShowLicenseClicked"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                HorizontalAlignment="Left" />
        <Grid Name="LicensePanel" IsVisible="False" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" Name="LicenseInput"
                     PlaceholderText="Paste your TBX1-… key" />
            <Button Grid.Column="1" Name="ActivateButton"
                    Content="Activate"
                    Click="OnActivateClicked" />
        </Grid>

        <TextBlock Name="StatusText" Opacity="0.7" FontSize="11" IsVisible="False" TextWrapping="Wrap" />
    </StackPanel>
</Window>
