<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeBarX.App.UpgradeProDialog"
        Title="Unlock TimeBarX Pro"
        WindowStartupLocation="CenterOwner"
        Width="420" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False">
    <StackPanel Margin="20" Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Background="#1E3A8A" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="11" FontWeight="SemiBold" />
            </Border>
            <TextBlock Text="Unlock TimeBarX Pro" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock TextWrapping="Wrap"
                   Text="A one-time $4.99 unlock for power users — no subscription, no account." />

        <StackPanel Spacing="6">
            <TextBlock Text="• Custom colors and gradient mode" />
            <TextBlock Text="• Bottom / taskbar-fill position" />
            <TextBlock Text="• Always above everything (experimental)" />
            <TextBlock Text="• timebarx:// URI automation (PowerToys, Flow, AutoHotkey)" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Name="DismissButton" Content="Not now" Click="OnDismissClicked" />
            <Button Name="RestoreButton" Content="Restore Purchase" Click="OnRestoreClicked" />
            <Button Name="BuyButton" Content="Unlock $4.99" Click="OnBuyClicked"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" />
        </StackPanel>

        <TextBlock Name="StatusText" Opacity="0.7" FontSize="11" IsVisible="False" TextWrapping="Wrap" />
    </StackPanel>
</Window>
