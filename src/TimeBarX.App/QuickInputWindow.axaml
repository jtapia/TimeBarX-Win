<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeBarX.App.QuickInputWindow"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        Width="420"
        Title="TimeBarX — Quick Timer">
    <!-- No explicit colors: inherit Avalonia FluentTheme so the window follows
         the system light/dark theme. The Border just supplies rounding + a
         subtle 1px outline since the window is undecorated. -->
    <Border CornerRadius="8"
            Padding="16"
            BorderThickness="1"
            Background="{DynamicResource SystemRegionBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <StackPanel Spacing="8">
            <TextBlock Text="Start a timer"
                       Opacity="0.7"
                       FontSize="12" />
            <TextBox Name="InputBox"
                     FontSize="20"
                     PlaceholderText="25 min, 1:30, 2h review PR…"
                     KeyDown="OnKeyDown" />
            <TextBlock Name="HintText"
                       Text="Enter to start  ·  Esc to cancel"
                       Opacity="0.55"
                       FontSize="11" />
        </StackPanel>
    </Border>
</Window>
