<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimeBarX.App"
        x:Class="TimeBarX.App.OverlayWindow"
        x:DataType="local:TrayController"
        WindowStartupLocation="Manual"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        Focusable="False"
        ShowActivated="False"
        Height="7">
    <Canvas Name="BarCanvas" ClipToBounds="True">
        <Rectangle Name="ProgressBar"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Height="7"
                   Width="0"
                   IsVisible="{Binding IsBarVisible}"
                   Fill="#3B82F6" />
    </Canvas>
</Window>
