<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimeBarX.App"
        x:Class="TimeBarX.App.SettingsWindow"
        x:DataType="local:TrayController"
        Title="TimeBarX Settings"
        WindowStartupLocation="CenterScreen"
        Width="520" Height="540"
        CanResize="False">
    <TabControl Margin="12">
        <TabItem Header="General">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12" Spacing="14">
                <TextBlock Text="Default duration" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Name="Default15" GroupName="DefaultDuration" Content="15 min" Click="OnDefault15Clicked" />
                    <RadioButton Name="Default25" GroupName="DefaultDuration" Content="25 min" Click="OnDefault25Clicked" />
                    <RadioButton Name="Default50" GroupName="DefaultDuration" Content="50 min" Click="OnDefault50Clicked" />
                    <RadioButton Name="Default90" GroupName="DefaultDuration" Content="90 min" Click="OnDefault90Clicked" />
                </StackPanel>
                <Separator />
                <CheckBox Name="SoundCheck" Content="Play sound when timer completes" Click="OnSoundCheckClicked" />
                <Separator />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox Name="AutoPauseCheck" Content="Auto-pause when idle for" Click="OnAutoPauseClicked" VerticalAlignment="Center" />
                    <NumericUpDown Name="AutoPauseMinutes"
                                   Minimum="1" Maximum="240" Increment="1"
                                   FormatString="0"
                                   Width="90"
                                   ValueChanged="OnAutoPauseMinutesChanged" />
                    <TextBlock Text="minutes" VerticalAlignment="Center" />
                </StackPanel>
                <Separator />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox Name="RecordHistoryCheck" Content="Record completed sessions" Click="OnRecordHistoryClicked" VerticalAlignment="Center" />
                    <Button Content="Show history file" Click="OnShowHistoryFileClicked" />
                </StackPanel>
                <Separator />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Custom presets" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Name="PresetsProChip"
                            IsVisible="False"
                            Background="#1E3A8A"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                    <Button Content="Manage presets…" Click="OnManagePresetsClicked" />
                </StackPanel>
                <Separator />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <CheckBox Name="AlwaysAboveCheck"
                              Content="Always above everything (experimental)"
                              Click="OnAlwaysAboveClicked" />
                    <Border Name="AlwaysAboveProChip"
                            IsVisible="False"
                            Background="#1E3A8A"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <Border Name="AlwaysAboveWarning"
                        IsVisible="False"
                        Background="#3F2A14"
                        BorderBrush="#A16207"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6">
                    <TextBlock Foreground="#FCD34D"
                               TextWrapping="Wrap"
                               Text="Experimental — may not work with all applications. Some games or anti-cheat systems may behave unexpectedly." />
                </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Appearance">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12" Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Color" FontWeight="SemiBold" />
                    <Border Name="ColorProChip"
                            IsVisible="False"
                            Background="#1E3A8A"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Name="ColorAccent" GroupName="Color" Content="Accent" Click="OnColorAccent" />
                    <RadioButton Name="ColorBlue"   GroupName="Color" Content="Blue"   Click="OnColorBlue" />
                    <RadioButton Name="ColorPurple" GroupName="Color" Content="Purple" Click="OnColorPurple" />
                    <RadioButton Name="ColorGreen"  GroupName="Color" Content="Green"  Click="OnColorGreen" />
                    <RadioButton Name="ColorRed"    GroupName="Color" Content="Red"    Click="OnColorRed" />
                </StackPanel>
                <Separator />
                <TextBlock Text="Height" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Name="HeightThin"   GroupName="Height" Content="Thin"   Click="OnHeight2" />
                    <RadioButton Name="HeightNormal" GroupName="Height" Content="Medium" Click="OnHeight3" />
                    <RadioButton Name="HeightThick"  GroupName="Height" Content="Large"  Click="OnHeight4" />
                </StackPanel>
                <Separator />
                <TextBlock Text="Position" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Name="PositionTop"    GroupName="Position" Content="Top"    Click="OnPositionTop" />
                    <RadioButton Name="PositionBottom" GroupName="Position" Content="Bottom" Click="OnPositionBottom" />
                </StackPanel>
                <Separator />
                <TextBlock Text="Opacity" FontWeight="SemiBold" />
                <Slider Name="OpacitySlider" Minimum="0.1" Maximum="1.0" TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="OnOpacityChanged" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <CheckBox Name="GradientCheck" Content="Gradient mode (green → red)" Click="OnGradientClicked" />
                    <Border Name="GradientProChip"
                            IsVisible="False"
                            Background="#1E3A8A"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Pomodoro">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" Spacing="14">
                    <CheckBox Name="PomodoroEnabledCheck" Content="Enable Pomodoro cycle" Click="OnPomodoroEnabledClicked" />
                    <TextBlock TextWrapping="Wrap" Foreground="#9CA3AF"
                               Text="When enabled, starting a Pomodoro cycle runs Work → Break → Work → … automatically. Every N work sessions the break is longer." />
                    <Separator />
                    <Grid ColumnDefinitions="180,120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Work duration (min)" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Name="PomodoroWork"
                                       Minimum="1" Maximum="240" Increment="1" FormatString="0"
                                       ValueChanged="OnPomodoroWorkChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Short break (min)" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="1" Grid.Column="1" Name="PomodoroShort"
                                       Minimum="1" Maximum="120" Increment="1" FormatString="0"
                                       ValueChanged="OnPomodoroShortChanged" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Long break (min)" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1" Name="PomodoroLong"
                                       Minimum="1" Maximum="240" Increment="1" FormatString="0"
                                       ValueChanged="OnPomodoroLongChanged" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Long break every" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Row="3" Grid.Column="1" Name="PomodoroLongEvery"
                                       Minimum="2" Maximum="12" Increment="1" FormatString="0"
                                       ValueChanged="OnPomodoroLongEveryChanged" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text=" work sessions" VerticalAlignment="Center" />
                    </Grid>
                    <Separator />
                    <CheckBox Name="PomodoroAutoAdvanceCheck" Content="Auto-advance to the next phase" Click="OnPomodoroAutoAdvanceClicked" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Shortcuts">
            <StackPanel Margin="12" Spacing="10">
                <TextBlock Text="Quick timer input" FontWeight="SemiBold" />
                <TextBlock Text="Ctrl + Shift + T" FontFamily="Cascadia Mono,Consolas,monospace" />
                <Separator />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Automation" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#1E3A8A" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="Pro" Foreground="#DBEAFE" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock TextWrapping="Wrap"
                           Text="With Pro, TimeBarX accepts timebarx:// URIs. See INTEGRATIONS.md for PowerToys, Flow Launcher, and AutoHotkey examples. (Without Pro these commands are ignored.)" />
            </StackPanel>
        </TabItem>

        <TabItem Header="About">
            <StackPanel Margin="12" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="TimeBarX" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="A timer that lives on the edge of your screen." HorizontalAlignment="Center" />
                <TextBlock Name="VersionText" HorizontalAlignment="Center" Foreground="#9CA3AF" />
                <TextBlock Name="UpdateText"
                           HorizontalAlignment="Center"
                           Foreground="#10B981"
                           IsVisible="False" />
                <Button Name="UpdateDownloadButton"
                        Content="Download update"
                        HorizontalAlignment="Center"
                        IsVisible="False"
                        Click="OnDownloadUpdateClicked" />
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
